# Public Supabase project URL — safe in client code.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key — safe in client code. RLS enforces access at the row level.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Server-only — NEVER expose to the browser. Used in route handlers, server
# actions, and RLS-bypassing admin tasks (e.g. seeding branches, super-admin CRUD).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Optional — apex domain for absolute URLs in OG tags / sitemap / Resend.
NEXT_PUBLIC_SITE_URL=https://anamatakahui.co.nz

# Optional — contact-form email notifications via Resend.
# All three required for email to send; otherwise the form just persists
# to the contact_enquiries table.
RESEND_API_KEY=re_xxx
CONTACT_FROM_EMAIL=noreply@anamatakahui.co.nz
CONTACT_TO_EMAIL=hello@anamatakahui.co.nz

# Optional — Local Contexts Hub integration (https://localcontextshub.org).
# Without LOCAL_CONTEXTS_API_KEY, the Hub attach action returns a friendly
# error and the public surfaces fall back to the cached catalogue.
LOCAL_CONTEXTS_API_KEY=
LOCAL_CONTEXTS_HUB_BASE_URL=https://localcontextshub.org/api/v2  # default
LOCAL_CONTEXTS_USE_SANDBOX=false

# Optional — Vercel Cron secret. Protects /api/cron/* endpoints.
# Generate via `openssl rand -base64 32`. Vercel sends this in
# Authorization: Bearer <CRON_SECRET> when invoking cron jobs.
CRON_SECRET=
